{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path'); if echo \"$FILE\" | grep -qE 'routeTree\\.gen|convex/_generated'; then echo 'Blocked: This file is auto-generated. Edit source files instead.' >&2; exit 2; fi"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-file-reading.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/block-file-editing.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/block-content-search.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/block-file-search.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/block-npm-yarn.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/block-no-verify.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/block-destructive.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check-convex-env.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check-untested-functions.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check-temporal-coupling.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check-diagrams.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check-docs-sync.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run .claude/hooks/stop-hook.ts"
          }
        ]
      }
    ]
  }
}
